# Secrets
.env
*.env

# LangGraph checkpoints
checkpoints.db

# Cross-run learnings (local institutional memory; un-ignore to share across the team)
learnings/

# Product profile (company product context; un-ignore to share across the team)
product/

# Run traces (observability output, one JSONL per run)
traces/

# Workspace output (generated per feature run; recreated at runtime via project_ctx.ensure_repo).
