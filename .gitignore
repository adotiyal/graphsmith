workspace/

# Local session artifacts (one-off backups / test inputs; not part of the platform)
.madclub_backup/
madclub_briefs/

# Claude Code per-user settings (settings.json is shareable; *.local.json is personal)
.claude/settings.local.json

# OS
.DS_Store
